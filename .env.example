# =============================================================================
# AGRI MARKETPLACE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env file to version control!

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
# Development API URL
API_URL_DEV=https://your-dev-api-url.azurewebsites.net

# Production API URL  
API_URL_PROD=https://your-production-api-url.azurewebsites.net

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT Token Configuration
JWT_TOKEN_KEY=marketplace_access_token
JWT_REFRESH_TOKEN_KEY=marketplace_refresh_token
JWT_USER_KEY=marketplace_user

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=AgriMarket
APP_VERSION=1.0.0

# Feature flags
USE_MOCK_API=true

# =============================================================================
# DEPLOYMENT
# =============================================================================
# Azure Deployment (if applicable)
AZURE_WEBAPP_NAME=your-azure-app-name
AZURE_RESOURCE_GROUP=your-resource-group

# =============================================================================
# SECURITY
# =============================================================================
# CORS settings (for server configuration)
CORS_ORIGIN=http://localhost:4200

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
